<Window x:Class="TradingScreener.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Trading Screener" Height="800" Width="1200" Background="#2d2d2d">

    <UniformGrid Rows="2" Columns="2">
        <Grid Margin="5" Background="#333">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Name="Input1" Text="BTCUSDT" Width="80" Margin="5"/>
                <ComboBox Name="Combo1" SelectionChanged="TimeframeChanged" Width="60" Margin="5">
                    <ComboBoxItem Content="1m" IsSelected="True"/>
                    <ComboBoxItem Content="5m"/>
                    <ComboBoxItem Content="15m"/>
                    <ComboBoxItem Content="1h"/>
                </ComboBox>
                <Button Content="OK" Click="ChangeSymbol_Click" Tag="1" Width="30" Margin="5"/>
                <Button Content="Reset" Click="ResetView_Click" Tag="1" Width="40" Margin="5"/>
            </StackPanel>
            <TextBlock Name="Label1" Text="BTC: ---" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5,5,0,0" Grid.Row="1" Panel.ZIndex="1"/>
            <Wpf:WpfPlot Name="Chart1" Grid.Row="1"/>
            <Wpf:WpfPlot Name="OiChart1" Grid.Row="2" Margin="5"/>
        </Grid>

        <Grid Margin="5" Background="#333">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Name="Input2" Text="ETHUSDT" Width="80" Margin="5"/>
                <ComboBox Name="Combo2" SelectionChanged="TimeframeChanged" Width="60" Margin="5">
                    <ComboBoxItem Content="1m" IsSelected="True"/>
                    <ComboBoxItem Content="5m"/>
                    <ComboBoxItem Content="15m"/>
                    <ComboBoxItem Content="1h"/>
                </ComboBox>
                <Button Content="OK" Click="ChangeSymbol_Click" Tag="2" Width="30" Margin="5"/>
                <Button Content="Reset" Click="ResetView_Click" Tag="2" Width="40" Margin="5"/>
            </StackPanel>
            <TextBlock Name="Label2" Text="ETH: ---" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5,5,0,0" Grid.Row="1" Panel.ZIndex="1"/>
            <Wpf:WpfPlot Name="Chart2" Grid.Row="1"/>
            <Wpf:WpfPlot Name="OiChart2" Grid.Row="2" Margin="5"/>
        </Grid>

        <Grid Margin="5" Background="#333">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Name="Input3" Text="SOLUSDT" Width="80" Margin="5"/>
                <ComboBox Name="Combo3" SelectionChanged="TimeframeChanged" Width="60" Margin="5">
                    <ComboBoxItem Content="1m" IsSelected="True"/>
                    <ComboBoxItem Content="5m"/>
                    <ComboBoxItem Content="15m"/>
                    <ComboBoxItem Content="1h"/>
                </ComboBox>
                <Button Content="OK" Click="ChangeSymbol_Click" Tag="3" Width="30" Margin="5"/>
                <Button Content="Reset" Click="ResetView_Click" Tag="3" Width="40" Margin="5"/>
            </StackPanel>
            <TextBlock Name="Label3" Text="SOL: ---" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5,5,0,0" Grid.Row="1" Panel.ZIndex="1"/>
            <Wpf:WpfPlot Name="Chart3" Grid.Row="1"/>
            <Wpf:WpfPlot Name="OiChart3" Grid.Row="2" Margin="5"/>
        </Grid>

        <Grid Margin="5" Background="#333">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Name="Input4" Text="BNBUSDT" Width="80" Margin="5"/>
                <ComboBox Name="Combo4" SelectionChanged="TimeframeChanged" Width="60" Margin="5">
                    <ComboBoxItem Content="1m" IsSelected="True"/>
                    <ComboBoxItem Content="5m"/>
                    <ComboBoxItem Content="15m"/>
                    <ComboBoxItem Content="1h"/>
                </ComboBox>
                <Button Content="OK" Click="ChangeSymbol_Click" Tag="4" Width="30" Margin="5"/>
                <Button Content="Reset" Click="ResetView_Click" Tag="4" Width="40" Margin="5"/>
            </StackPanel>
            <TextBlock Name="Label4" Text="BNB: ---" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5,5,0,0" Grid.Row="1" Panel.ZIndex="1"/>
            <Wpf:WpfPlot Name="Chart4" Grid.Row="1"/>
            <Wpf:WpfPlot Name="OiChart4" Grid.Row="2" Margin="5"/>
        </Grid>
    </UniformGrid>
</Window>